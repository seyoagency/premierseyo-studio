{
  "id": "com.seyoweb.premierseyostudio",
  "name": "PremierSEYO Studio",
  "version": "2.0.1",
  "main": "src/index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.6.0"
  },
  "manifestVersion": 5,
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "clipboard": "readAndWrite",
    "network": {
      "domains": "all"
    },
    "launchProcess": {
      "schemes": ["http", "https"],
      "extensions": ["", ".srt", ".vtt", ".wav", ".txt"]
    },
    "allowCodeGenerationFromStrings": true
  },
  "entrypoints": [
    {
      "id": "premierseyo-studio-panel",
      "type": "panel",
      "label": {
        "default": "PremierSEYO Studio"
      },
      "minimumSize": {
        "width": 320,
        "height": 480
      },
      "maximumSize": {
        "width": 720,
        "height": 1400
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 720
      },
      "preferredFloatingSize": {
        "width": 460,
        "height": 820
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/icon-dark.png",
          "scale": [1, 2],
          "theme": ["darkest", "dark", "medium"]
        },
        {
          "width": 23,
          "height": 23,
          "path": "icons/icon-light.png",
          "scale": [1, 2],
          "theme": ["lightest", "light"]
        }
      ]
    }
  ],
  "icons": [
    {
      "width": 48,
      "height": 48,
      "path": "icons/icon-dark.png",
      "scale": [1, 2],
      "theme": ["darkest", "dark", "medium", "lightest", "light", "all"],
      "species": ["pluginList"]
    }
  ]
}
